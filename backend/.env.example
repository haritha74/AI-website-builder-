FLASK_ENV=development
SECRET_KEY=change-this-secret-in-production
JWT_SECRET_KEY=change-this-jwt-secret-in-production
DATABASE_URL=sqlite:///ai_website_builder.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash-lite,gemini-flash-lite-latest
GEMINI_TIMEOUT_SECONDS=180
GEMINI_VERIFY_SSL=true
FRONTEND_ORIGIN=http://localhost:5173
RESET_BASE_URL=http://localhost:5173/reset-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@aiwebsitebuilder.local
